# Optional: n8n webhook URL. When set, "Activate workflow" will POST lead data here.
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/xxxx

# Optional: API key for n8n to call the dashboard. If set, n8n must send
# X-Api-Key: <value> or ?apiKey=<value> when calling /api/n8n/leads
# N8N_API_KEY=your-secret-key
