# Optional: n8n webhook URL. When set, "Activate workflow" will POST lead data here.
# N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/xxxx

# Optional: API key for n8n to call the dashboard. If set, n8n must send
# X-Api-Key: <value> or ?apiKey=<value> when calling /api/n8n/leads
# N8N_API_KEY=your-secret-key

# Session signing (recommended in production: min 16 characters). If unset, a built-in dev fallback is used (rotate for anything internet-facing).
# BLOCHARCH_SESSION_SECRET=change-me-to-a-long-random-string

# First-run bootstrap admin when data/users.json is created (defaults: blocharch / blocharch)
# BLOCHARCH_ADMIN_USERNAME=blocharch
# BLOCHARCH_ADMIN_PASSWORD=blocharch

# Optional: absolute or project-relative path to users.json (default: data/users.json; on Vercel: /tmp/blocarch-users.json)
# BLOCHARCH_USERS_FILE=/tmp/blocarch-users.json
